  "keyFeatures": [
    "Debug .NET Framework, .NET Core, and Unity game assemblies without source code",
    "Edit .NET assemblies: methods, classes, and metadata in C# or Visual Basic",
    "IL editor for low-level method body editing",
    "Hex editor with .NET metadata and PE structure highlighting",
    "C# Interactive scripting window for automating dnSpy",
    "Search assemblies for classes, methods, strings, and more",
    "Analyzer to find callers, type usage, and member references",
    "Conditional breakpoints, tracepoints, and expression evaluation",
    "Export/import breakpoints and decompile to project",
    "Plugin/extension API with MEF-based composition",
    "Light, dark, and high-contrast themes",
    "BAML decompiler for WPF resource inspection"
  ],
  "publicApiSurface": [
    "IExtension (dnSpy.Contracts.Extension)",
    "ExportExtensionAttribute",
    "DbgManager (debugger lifecycle management)",
    "DbgProcess, DbgThread, DbgModule, DbgRuntime",
    "DbgCodeBreakpoint, DbgCodeBreakpointsService",
    "DbgExpressionEvaluator, DbgLanguage, DbgValue",
    "IDsDocumentService (assembly document management)",
    "IDsDocument, IDsDotNetDocument, IDsPEDocument",
    "IThemeService, ITheme (theming API)",
    "IDocumentSearcher, IDocumentSearcherProvider",
    "HexBufferFactoryService, HexBuffer (hex editor API)",
    "IAutoLoaded (MEF auto-loaded extensions)"
  ]
